# Example iOS helper plugin configuration.
#
# Copy this file to ~/.idapro/ioshelper.cfg and edit it to taste. Every setting is
# optional; the values below are the defaults, so an absent (or empty) config file
# behaves exactly like this one.

# Development conveniences: the F2 reload and F4 toggle (optimizations on/off)
# hotkeys, plus debug-only components.
debug = false

# Feature groups to skip entirely. Known features: "objc", "swift".
# e.g. disabled_features = ["swift"] drops Swift support on a pure Obj-C binary.
disabled_features = []

# Individual components to skip, by name (finer-grained than disabled_features).
# See the "Components" tables in the README for every available name.
# e.g. disabled_components = ["swift-strings", "objc-optimizers"]
disabled_components = []

# Work-in-progress components to opt into, by name. These are disabled by default.
# e.g. experimental_components = ["objc-msgsend-argcount", "dsc-stub-calls"]
experimental_components = []

# Per-component settings: a TOML table named after a component holds that component's
# own options. Every key is optional; the values shown are the defaults.

# Which name sources the Obj-C lvar renamer (`objc-lvar-renamer`) runs.
# [objc-lvar-renamer]
# args = true          # the function's own selector names its arguments
# getters = false      # a variable assigned from a getter is named after it (WIP)
# callee-args = false  # a variable passed at a selector keyword position (WIP)
